<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_bg_dark">

    <!-- ═══ Row 1: Header — Title + Power Toggle ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <!-- Status dot + Title -->
        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🦀 ZeroClaw"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <!-- ON/OFF toggle button -->
        <TextView
            android:id="@+id/widget_toggle_btn"
            android:layout_width="56dp"
            android:layout_height="26dp"
            android:text="Start"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/widget_btn_start" />
    </LinearLayout>

    <!-- ═══ Row 2: Live Status Pill ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/widget_status_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ Idle"
            android:textSize="10sp"
            android:textColor="#00D4AA"
            android:background="@drawable/widget_status_pill"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp" />

        <TextView
            android:id="@+id/widget_uptime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textSize="9sp"
            android:textColor="#666666"
            android:gravity="end"
            android:paddingEnd="4dp" />
    </LinearLayout>

    <!-- ═══ Row 3: Connected Bots ═══ -->
    <LinearLayout
        android:id="@+id/widget_bots_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_bots_bg"
        android:padding="6dp"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/widget_bots_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bots:"
            android:textSize="9sp"
            android:textColor="#888888"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/widget_bots_icons"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="No bots connected"
            android:textSize="11sp"
            android:textColor="#CCCCCC"
            android:singleLine="true" />

        <TextView
            android:id="@+id/widget_bots_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="9sp"
            android:textColor="#58A6FF" />
    </LinearLayout>

    <!-- ═══ Row 4: Agent Stats + Tunnel ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/widget_agents_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🕷️ 0 agents"
            android:textSize="10sp"
            android:textColor="#B0B0B0" />

        <TextView
            android:id="@+id/widget_tunnel_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="9sp"
            android:textColor="#F6821F"
            android:singleLine="true"
            android:maxWidth="140dp"
            android:ellipsize="middle" />
    </LinearLayout>

    <!-- ═══ Row 5: Last Activity ═══ -->
    <TextView
        android:id="@+id/widget_last_activity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="9sp"
        android:textColor="#666666"
        android:singleLine="true"
        android:ellipsize="end"
        android:layout_marginBottom="6dp" />

    <!-- ═══ Row 6: Quick Action Buttons ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_btn_agents"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:text="🕷️ Agents"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#58A6FF"
            android:gravity="center"
            android:background="@drawable/widget_btn_action"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/widget_btn_chat"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:text="💬 Chat"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#58A6FF"
            android:gravity="center"
            android:background="@drawable/widget_btn_action"
            android:layout_marginStart="4dp" />
    </LinearLayout>

</LinearLayout>
